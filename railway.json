{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "backend-qr/Dockerfile.prod"
  },
  "deploy": {
    "startCommand": "sh -c 'npx --no-install prisma db push --skip-generate && npx --no-install prisma db seed && node src/app.js'",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "port": 5000
  }
}
