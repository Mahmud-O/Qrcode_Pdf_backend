# Port the server will listen on
PORT=5050

# Node environment (development, production)
NODE_ENV=development

# Database connection string (PostgreSQL database url required by Prisma)
DATABASE_URL="postgresql://your.railway.internal:5432/railway"

# Secret key for signing and verifying JWT tokens (Use a strong random string in production)
JWT_SECRET="QR_jwt_key_here"

# JWT token expiration time (optional, default is '8h')
JWT_EXPIRES_IN="24h"

# Seed administrator credentials (used to seed/check the admin user)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123123"

# Allowed origins for CORS (comma-separated origins or * for all)
CORS_ORIGIN="*"

# Base URL for generated QR code links (URL pointing to the public PDF page)
PUBLIC_APP_URL="http://localhost:5050"

# Maximum file size for document uploads in Megabytes (optional, default is 20)
MAX_FILE_SIZE_MB=20
